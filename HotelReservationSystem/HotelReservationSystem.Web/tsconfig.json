{
  "compilerOptions": {
    "noImplicitAny": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": true,
    "strict": true,

    "module": "esnext",
    "moduleResolution": "bundler",

    "target": "es6",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    "outDir": "wwwroot/js",
    "rootDir": "Scripts",

    "skipLibCheck": true
  },

  "include": [
    "Scripts/**/*"
  ],

  "exclude": [
    "node_modules",
    "wwwroot"
  ]
}